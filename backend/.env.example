# ── App Settings ──────────────────────────────────────
APP_NAME=Smart Baby Band API
APP_VERSION=1.0.0
DEBUG=True

# ── Firebase ──────────────────────────────────────────
# Path to your Firebase service account JSON key file
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed origins
# Use * for development, restrict in production
CORS_ORIGINS=["*"]

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── ML Model ──────────────────────────────────────────
CRY_MODEL_PATH=ml_models/cry_detection_model.tflite
